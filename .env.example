# setup-host.sh and deploy.sh rewrite these to the current checkout path.
NATS_CONFIG_PATH=/opt/nangman-crypto/apps/nats-server-app/nats-server.conf
NATS_DATA_ROOT=/opt/nangman-crypto/data/nats
# Bind the client port to 0.0.0.0 so LAN/WireGuard clients can reach it.
# For a single-interface LAN bind, override this in .env, for example:
# NATS_CLIENT_BIND=192.168.10.45
NATS_CLIENT_BIND=0.0.0.0
NATS_CLIENT_PORT=4222
NATS_MONITOR_BIND=127.0.0.1
NATS_MONITOR_PORT=8222
NATS_RAW_INTEL_STREAM_MAX_AGE=168h
NATS_STRUCTURED_INTEL_STREAM_MAX_AGE=336h
NATS_STRUCTURED_INTEL_STREAM_DUPLICATE_WINDOW=24h
NATS_INTEL_CANDIDATE_STREAM_MAX_AGE=336h
NATS_INTEL_CANDIDATE_STREAM_DUPLICATE_WINDOW=24h
NANGMAN_NATS_DOCKER_NETWORK=nangman-crypto-bus
